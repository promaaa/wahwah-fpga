flowchart LR
    I2S_RX["Interface I2S RX - D_L_O / D_R_O : 24 bits"] --> AUDIO_IN["Flux audio stéréo - Fs = 48 kHz"]

    subgraph DSP["Chaîne DSP LUT-optimisée (dupliquée L/R)"]
        AUDIO_IN --> PREP["Pré-traitement - Chemin direct 24 bits signés"]

        subgraph CTRL["Contrôle de l'index LUT"]
            UI["UI (switches) - config_sw[2:0] : vitesse LFO - config_sw[4] : bypass effet"] --> LFO
            LFO["LFO numérique - Accu phase : 32 bits - 8 vitesses : 0.5..5.0 Hz"] --> SCALE["Mise à l'échelle - index = phase[31:24] - 8 bits => 0..255"]
        end

        subgraph MEM["Mémoire coefficients"]
            LUT[("ROM coeffs - Profondeur : 256 - Largeur : 3 x 24 bits - Format : Q1.22 - Sorties : b0, -a1, -a2")]
        end

        SCALE -->|"index[7:0]"| LUT
        LUT -->|"b0, -a1, -a2"| IIR

        PREP --> IIR["Filtre IIR biquad DF1 - Ordre 2 - Entrée/sortie : 24 bits - MAC : 4 cycles/échantillon - Accu : 56 bits - Shift : >>22 + saturation"]
        IIR --> SEL_FX{"Bypass ? - config_sw[4]"}
        PREP --> SEL_FX
        SEL_FX --> POST["Post-traitement - Gain makeup x2 + saturation 24 bits"]
    end

    POST --> MIX["Mix / routage global - Bouton : dry/wet global"]
    MIX --> I2S_TX["Interface I2S TX - D_L_I / D_R_I : 24 bits"]

    CLK["Horloges - CLK sys : 100 MHz - MCLK/BCLK/LRCLK codec - Cadence DSP : pulse48kHz"] --> I2S_RX
    CLK --> DSP
    CLK --> I2S_TX
